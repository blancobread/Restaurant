{
  "$schema": "https://biomejs.dev/schemas/1.7.0/schema.json",

  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },

  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,

      "suspicious": {
        "noExplicitAny": "off"
      },

      "style": {
        "useConst": "warn",
        "noUnusedVariables": "warn"
      },

      "complexity": {
        "noUselessFragments": "warn"
      }
    }
  },

  "organizeImports": {
    "enabled": true
  }
}
